# Ethereum ノード接続先（Infura/Alchemy などの RPC エンドポイント）
# デフォルト（WEB3J_CLIENT_ADDRESS が fallback として使われる）
WEB3J_CLIENT_ADDRESS=

# チェーン別エンドポイント（省略時は WEB3J_CLIENT_ADDRESS が使われる）
# Polygon Mainnet: https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID
WEB3J_POLYGON_ENDPOINT=
# Ethereum Mainnet: https://mainnet.infura.io/v3/YOUR_PROJECT_ID
WEB3J_ETHEREUM_ENDPOINT=

# データベース（本番: PostgreSQL 必須）
# 例: jdbc:postgresql://localhost:5432/paymentdb
DB_URL=
DB_USERNAME=
DB_PASSWORD=
DB_DRIVER=org.postgresql.Driver

# 決済設定
PAYMENT_DEFAULT_TTL_SECONDS=3600
