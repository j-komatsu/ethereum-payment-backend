# Ethereum ノード接続先（どちらか1つ設定すれば動く）
# Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# Infura:  https://polygon-mainnet.infura.io/v3/YOUR_KEY
# ローカル: http://localhost:8545 （Hardhat ノード）
WEB3J_CLIENT_ADDRESS=http://localhost:8545

# チェーン別エンドポイント（省略時は WEB3J_CLIENT_ADDRESS が使われる）
WEB3J_POLYGON_ENDPOINT=
WEB3J_ETHEREUM_ENDPOINT=

# データベース
# dev プロファイル使用時は application-dev.yml の H2 設定が優先されるため不要
DB_URL=jdbc:postgresql://localhost:5432/paymentdb
DB_USERNAME=postgres
DB_PASSWORD=
DB_DRIVER=org.postgresql.Driver

# JWT 認証
# 生成例: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRY_SECONDS=86400

# SIWE（Sign-In With Ethereum）
SIWE_DOMAIN=localhost
SIWE_CHAIN_ID=137
SIWE_NONCE_TTL_SECONDS=300

# Permit 実行者ウォレット（EIP-2612 Permit + transferFrom を実行するウォレットの秘密鍵）
# ⚠️ 本番環境では HSM / Vault に移管すること
# ⚠️ このファイルを Git にコミットしないこと
PERMIT_SPENDER_PRIVATE_KEY=

# 決済設定
PAYMENT_DEFAULT_TTL_SECONDS=3600
PAYMENT_MAX_TTL_SECONDS=86400

# TransferEvent ポーラー設定
POLLER_ENABLED=true
POLLER_INTERVAL_MS=15000
