# Ethereum ノード接続先（Infura/Alchemy などの RPC エンドポイント）
# Polygon: https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID
# テスト用: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
WEB3J_CLIENT_ADDRESS=

# データベース（本番: PostgreSQL 必須）
# 例: jdbc:postgresql://localhost:5432/paymentdb
DB_URL=
DB_USERNAME=
DB_PASSWORD=
DB_DRIVER=org.postgresql.Driver

# 決済設定
PAYMENT_DEFAULT_TTL_SECONDS=3600
